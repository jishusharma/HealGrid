<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Grid UI Parallel Classes" verbose="1" parallel="classes" thread-count="4">
    <parameter name="execution" value="grid"/>
    <parameter name="grid.url" value="http://localhost:4444"/>
    <listeners>
        <listener class-name="utils.listeners.TestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    <test name="Chrome Tests (grid)">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.DemoQAMainPageTest"/>
            <class name="tests.DemoQAElementsPageTest"/>
        </classes>
    </test>
</suite>